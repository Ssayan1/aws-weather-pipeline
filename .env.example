# ============================================================
#  .env — Environment variables for AWS Weather Pipeline
#  COPY THIS FILE TO .env AND FILL IN YOUR VALUES.
#  NEVER commit .env to Git (it is in .gitignore).
# ============================================================

# ── OpenWeather API ──────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Cities to fetch (comma-separated)
WEATHER_CITIES=London,New York,Tokyo,Sydney,Mumbai

# Unit system: metric (°C) | imperial (°F) | standard (K)
WEATHER_UNITS=metric


# ── AWS Credentials ──────────────────────────────────────────
# Tip: if you configure AWS CLI (`aws configure`), you can leave
# these blank and boto3 will use the default credential chain.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1


# ── S3 ────────────────────────────────────────────────────────
# Must be globally unique — change the suffix to something unique
S3_BUCKET_NAME=weather-pipeline-yourname-2024

# Where Athena writes query result files (must be in same bucket)
S3_ATHENA_RESULTS=s3://weather-pipeline-yourname-2024/athena-results/


# ── AWS Glue ─────────────────────────────────────────────────
GLUE_DATABASE=weather_db
GLUE_TABLE=weather_data
GLUE_CRAWLER_NAME=weather-crawler


# ── Athena ────────────────────────────────────────────────────
ATHENA_DATABASE=weather_db


# ── Logging ──────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
